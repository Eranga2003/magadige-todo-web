datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                      String   @id @default(uuid())
  email                   String?  @unique
  passwordHash            String?  // Nullable for social-only sign-up users
  name                    String
  googleId                String?  @unique
  facebookId              String?  @unique
  usageType               String?  // "OWN" (own usage) or "TEAM" (team usage)
  currentManagementMethod String?  // "PAPER" (writing on paper) or "APP" (using an app)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
